HOST=0.0.0.0
PORT=1337
APP_KEYS="tobemodified1,tobemodified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified

# ─── Frontend (Next.js on Vercel) ────────────────────────────────
CLIENT_URL=http://localhost:3000
PREVIEW_SECRET=preview_secret # optional, required with Next.js draft mode
NEXT_REVALIDATE_URL=http://localhost:3000/api/revalidate
REVALIDATE_WEBHOOK_SECRET=revalidate_webhook_secret

# ─── Public URL (how Strapi is accessed publicly) ───────────────
# Set this in production so uploaded media URLs are absolute.
# Example: https://api.meetswiss.com
PUBLIC_URL=

# ─── Database (production: PostgreSQL) ──────────────────────────
# For local development, defaults to SQLite (no config needed).
# For production (Dokploy), set these:
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgresql://user:password@host:5432/strapi
# OR use individual vars:
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=strapi
# DATABASE_USERNAME=strapi
# DATABASE_PASSWORD=strapi
# DATABASE_SSL=false

WEBSITE_URL=http://localhost:3000 # Add the correct ENV var for this onto your hosting platform, point it to your production website.
ENVIRONMENT=development
PORT=3000

# ─── Strapi API URL ─────────────────────────────────────────────
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:1337
# Production (set in Vercel dashboard):
# NEXT_PUBLIC_API_URL=https://api.meetswiss.com

# ─── Image Optimization ─────────────────────────────────────────
# Hostname for Next.js image optimization (just the hostname, no protocol).
# Must match your Strapi domain. Set in Vercel dashboard for production.
# IMAGE_HOSTNAME=api.meetswiss.com

# ─── Secrets ─────────────────────────────────────────────────────
PREVIEW_SECRET=preview_secret
REVALIDATE_WEBHOOK_SECRET=revalidate_webhook_secret

# ─── Email (Contact Form) ───────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=smtp-user
SMTP_PASS=smtp-password
SMTP_FROM="Meetswiss Transfers <no-reply@meetswiss.com>"
SMTP_TO=contact@meetswiss.com
CONTACT_SUBJECT_PREFIX=Meetswiss Transfers

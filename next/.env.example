WEBSITE_URL=https://meetswiss-transfers.vercel.app
ENVIRONMENT=production
PORT=3000

# ─── Strapi API URL ─────────────────────────────────────────────
# Production deployment:
NEXT_PUBLIC_API_URL=https://meetswiss-api-ujpbld-f99bdb-79-76-127-182.traefik.me

# ─── Image Optimization ─────────────────────────────────────────
# Hostname for Next.js image optimization (just the hostname, no protocol).
# Must match your Strapi domain.
IMAGE_HOSTNAME=meetswiss-api-ujpbld-f99bdb-79-76-127-182.traefik.me

# ─── Secrets ─────────────────────────────────────────────────────
PREVIEW_SECRET=preview_secret
REVALIDATE_WEBHOOK_SECRET=revalidate_webhook_secret

# ─── Email (Contact Form) ───────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=smtp-user
SMTP_PASS=smtp-password
SMTP_FROM="Meetswiss Transfers <no-reply@meetswiss.com>"
SMTP_TO=contact@meetswiss.com
CONTACT_SUBJECT_PREFIX=Meetswiss Transfers
